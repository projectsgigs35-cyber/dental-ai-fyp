# Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/FYP

# JWT Secret for authentication
JWT_SECRET=your-jwt-secret-key-here

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Roboflow API Keys for AI Detection Models
ROBOFLOW_OPG_API_KEY=your-roboflow-api-key
ROBOFLOW_PLAG_API_KEY=your-roboflow-api-key

# Roboflow Model Names
ROBOFLOW_OPG_MODEL=dental-x-ray-panoramic-dataset-ewhpw/1
ROBOFLOW_PLAG_MODEL=master-plaque-aly9i/1

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173
